{
	// Biome configuration for SvelteKit project
	// Svelte files require special overrides due to partial support in Biome
	// See: https://biomejs.dev/internals/language-support/#html-super-languages-support
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": [
				"**/*.svelte"
			],
			"linter": {
				"rules": {
					"style": {
						"useConst": "off",
						// "useImportType": "off" // keep "off" as advised by Biome for Svelte projects as it's not supported yet, but let's try it out
					},
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		}
	]
}