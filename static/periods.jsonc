		"duration": 1961200000,
		"name": {
			"en": "Proterozoic",
			"fr": "Protérozoïque"
		},
		"description": {
			"en": "Development of complex life forms, including the first multicellular organisms and the emergence of sexual reproduction. Major geological events include the formation of supercontinents and significant atmospheric changes.",
			"fr": "Développement de formes de vie complexes, incluant les premiers organismes multicellulaires et l'émergence de la reproduction sexuée. Événements géologiques majeurs incluent la formation de supercontinents et des changements atmosphériques significatifs."
		},
		"color": "#15803D",
		"image": null
	},
	{
		"id": 4,
		"parentPeriodId": null,
		"start": -538800000,
		"end": 2015,
		"startUncertainty": 600000,
		"endUncertainty": 0,
		"duration": 538802015,
		"name": {
			"en": "Phanerozoic",
			"fr": "Phanérozoïque"
		},
		"description": {
			"en": "The current eon of visible life, characterized by the proliferation of complex multicellular organisms. Includes the Paleozoic, Mesozoic, and Cenozoic eras, featuring the evolution of vertebrates, plants, and the rise and fall of dinosaurs.",
			"fr": "L'éon actuel de la vie visible, caractérisé par la prolifération d'organismes multicellulaires complexes. Inclut les ères Paléozoïque, Mésozoïque et Cénozoïque, avec l'évolution des vertébrés, des plantes, et l'essor et la chute des dinosaures."
		},
		"color": "#1D4ED8",
		"image": null
	},
	{
		"id": 5,
		"parentPeriodId": 3,
		"start": -2500000000,
		"end": -1600000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 900000000,
		"name": {
			"en": "Paleoproterozoic",
			"fr": "Paléoprotérozoïque"
		},
		"description": {
			"en": "First eukaryotes. Oxygen-rich atmosphere, cause of the Great Oxidation Event. Huronian glaciation.",
			"fr": "Premiers eucaryotes. Atmosphère riche en dioxygène, cause de la grande oxydation. Glaciation huronienne."
		},
		"color": "#166534",
		"image": null
	},
	{
