		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 600000000,
		"name": {
			"en": "Mesoproterozoic",
			"fr": "Mésoprotérozoïque"
		},
		"description": {
			"en": "Formation of the supercontinent Rodinia. Development of sexual reproduction in eukaryotes. Stable oxygen levels in the atmosphere. First evidence of complex multicellular life.",
			"fr": "Formation du supercontinent Rodinia. Développement de la reproduction sexuée chez les eucaryotes. Niveaux d'oxygène stables dans l'atmosphère. Premières preuves de vie multicellulaire complexe."
		},
		"color": "#0F766E",
		"image": null
	},
	{
		"id": 7,
		"parentPeriodId": 3,
		"start": -1000000000,
		"end": -538800000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 461200000,
		"name": {
			"en": "Neoproterozoic",
			"fr": "Néoprotérozoïque"
		},
		"description": {
			"en": "Breakup of Rodinia supercontinent. Multiple global glaciations including Snowball Earth events. Emergence of complex multicellular life including the Ediacaran biota. Precursor to the Cambrian explosion.",
			"fr": "Fragmentation du supercontinent Rodinia. Multiples glaciations globales incluant les événements Terre boule de neige. Émergence de vie multicellulaire complexe incluant la biote de l'Édiacarien. Précurseur de l'explosion cambrienne."
		},
		"color": "#0369A1",
		"image": null
	},
	{
		"id": 12,
		"parentPeriodId": 5,
		"start": -2500000000,
		"end": -2300000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 200000000,
		"name": {
			"en": "Siderian",
			"fr": "Sidérien"
		},
		"description": {
			"en": "The opening period of the Paleoproterozoic, when Earth's atmosphere began to fill with oxygen produced by early bacteria. Banded iron formations provide evidence of this major change, which would transform the planet's chemistry.",
			"fr": "Première période du Paléoprotérozoïque, lorsque l'atmosphère terrestre commence à s'enrichir en oxygène produit par des bactéries primitives. Les formations de fer rubané témoignent de ce bouleversement chimique majeur."
		},
		"color": "#14532D",
		"image": null
	},
	{
		"id": 13,
		"parentPeriodId": 5,
		"start": -2300000000,
		"end": -2050000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 250000000,
		"name": {
			"en": "Rhyacian",
			"fr": "Rhyacien"
		},
		"description": {
			"en": "A period when oxygen continued to build up in the atmosphere during the Great Oxidation Event. The rising oxygen levels fundamentally altered how minerals formed and paved the way for more complex life.",
			"fr": "Période durant laquelle l'oxygène continue de s'accumuler dans l'atmosphère lors de la grande oxydation. Ces niveaux croissants modifient profondément la formation des minéraux et ouvrent la voie à une vie plus complexe."
		},
		"color": "#047857",
		"image": null
	},
	{
		"id": 14,
		"parentPeriodId": 5,
		"start": -2050000000,
		"end": -1800000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 250000000,
		"name": {
			"en": "Orosirian",
			"fr": "Orosirien"
		},
		"description": {
			"en": "A relatively stable period of the early Paleoproterozoic before the great Huronian glaciation. Continents continued to grow and cluster, while oxygen levels remained high in the atmosphere.",
			"fr": "Période relativement stable du début du Paléoprotérozoïque, avant la grande glaciation huronienne. Les continents continuent de croître et de se regrouper, tandis que l'atmosphère reste riche en oxygène."
		},
		"color": "#059669",
		"image": null
	},
	{
