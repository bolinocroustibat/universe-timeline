		"endUncertainty": 0,
		"duration": 200000000,
		"name": {
			"en": "Siderian",
			"fr": "Sidérien"
		},
		"description": {
			"en": "The opening period of the Paleoproterozoic, when Earth's atmosphere began to fill with oxygen produced by early bacteria. Banded iron formations provide evidence of this major change, which would transform the planet's chemistry.",
			"fr": "Première période du Paléoprotérozoïque, lorsque l'atmosphère terrestre commence à s'enrichir en oxygène produit par des bactéries primitives. Les formations de fer rubané témoignent de ce bouleversement chimique majeur."
		},
		"color": "#14532D",
		"image": null
	},
	{
		"id": 13,
		"parentPeriodId": 5,
		"start": -2300000000,
		"end": -2050000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 250000000,
		"name": {
			"en": "Rhyacian",
			"fr": "Rhyacien"
		},
		"description": {
			"en": "A period when oxygen continued to build up in the atmosphere during the Great Oxidation Event. The rising oxygen levels fundamentally altered how minerals formed and paved the way for more complex life.",
			"fr": "Période durant laquelle l'oxygène continue de s'accumuler dans l'atmosphère lors de la grande oxydation. Ces niveaux croissants modifient profondément la formation des minéraux et ouvrent la voie à une vie plus complexe."
		},
		"color": "#047857",
		"image": null
	},
	{
