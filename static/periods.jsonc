		"endUncertainty": 0,
		"duration": 200000000,
		"name": {
			"en": "Statherian",
			"fr": "Stathérien"
		},
		"description": {
			"en": "Emergence of the Columbia continent",
			"fr": "Émergence du continent Columbia"
		},
		"color": "#10B981",
		"image": null
	},
	{
		"id": 16,
		"parentPeriodId": 2,
		"start": -4000000000,
		"end": -3600000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 400000000,
		"name": {
			"en": "Eoarchean",
			"fr": "Eoarchéen"
		},
		"description": {
			"en": "The earliest division of the Archean, when Earth was still a hot, young planet with a barely solid crust. The oldest known rocks on Earth date from this period, though few traces of life have survived.",
			"fr": "Première division de l'Archéen, lorsque la Terre est encore une planète jeune et brûlante à la croûte à peine solidifiée. Les roches les plus anciennes connues datent de cette période, mais peu de traces de vie ont survécu."
		},
		"color": "#9A3412",
		"image": null
	},
	{
		"id": 17,
		"parentPeriodId": 2,
		"start": -3600000000,
		"end": -3200000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 400000000,
		"name": {
			"en": "Paleoarchean",
			"fr": "Paléoarchéen"
		},
		"description": {
			"en": "A period when the first stable continental crust formed and volcanic activity shaped the young landmasses. Isotopic evidence suggests that life may have emerged in the oceans during this time.",
			"fr": "Période durant laquelle se forme la première croûte continentale stable et l'activité volcanique façonne les jeunes terres émergées. Des indices isotopiques suggèrent que la vie serait apparue dans les océans à cette époque."
		},
		"color": "#B45309",
		"image": null
	},
	{
		"id": 18,
		"parentPeriodId": 2,
		"start": -3200000000,
		"end": -2800000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 400000000,
		"name": {
			"en": "Mesoarchean",
			"fr": "Mésoarchéen"
		},
		"description": {
			"en": "A middle phase of the Archean marked by the growth of small proto-continents and active hydrothermal systems on the ocean floor. Fossil evidence points to thriving microbial communities in shallow marine environments.",
			"fr": "Phase intermédiaire de l'Archéen marquée par la croissance de petits proto-continents et des systèmes hydrothermaux actifs au fond des océans. Des fossiles attestent de communautés microbiennes florissantes en eaux peu profondes."
		},
		"color": "#D97706",
		"image": null
	},
	{
		"id": 19,
		"parentPeriodId": 2,
		"start": -2800000000,
		"end": -2500000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 300000000,
		"name": {
			"en": "Neoarchean",
			"fr": "Néoarchéen"
		},
		"description": {
			"en": "The final period of the Archean, when continents grew larger and the oldest widely accepted evidence of life appears in the fossil record. At its end, the planet was ready to enter the oxygen-rich Proterozoic era.",
			"fr": "Dernière période de l'Archéen, lorsque les continents s'agrandissent et que les plus anciennes traces de vie largement acceptées apparaissent dans le registre fossile. À sa fin, la planète est prête à entrer dans le Protérozoïque."
		},
		"color": "#F59E0B",
		"image": null
	},
	{
		"id": 20,
		"parentPeriodId": 6,
		"start": -1600000000,
		"end": -1400000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 200000000,
		"name": {
			"en": "Calymmian",
			"fr": "Calymmien"
		},
		"description": {
			"en": "The opening period of the Mesoproterozoic, a long interval of relative geological calm. Shallow seas covered wide areas, and the first steps toward sexual reproduction may have taken place among microscopic organisms.",
			"fr": "Première période du Mésoprotérozoïque, long intervalle de calme géologique relatif. Des mers peu profondes couvrent de vastes zones et les premiers pas vers la reproduction sexuée pourraient avoir lieu chez des organismes microscopiques."
		},
		"color": "#115E59",
		"image": null
	},
	{
		"id": 21,
		"parentPeriodId": 6,
		"start": -1400000000,
		"end": -1200000000,
		"startUncertainty": 0,
		"endUncertainty": 0,
		"duration": 200000000,
		"name": {
			"en": "Ectasian",
			"fr": "Ectasien"
		},
		"description": {
			"en": "A quiet period of the Mesoproterozoic marked by the continued assembly of the supercontinent Rodinia. Life remained mostly microbial, but eukaryotic cells were becoming more widespread in the oceans.",
			"fr": "Période calme du Mésoprotérozoïque marquée par la poursuite de l'assemblage du supercontinent Rodinia. La vie reste essentiellement microbienne, mais les cellules eucaryotes se répandent dans les océans."
		},
		"color": "#0D9488",
		"image": null
	},
	{
